# FlashGuides local development environment
# Copy this file to .env for local development. Never commit real secrets.
# For Vercel production values, use .env.vercel.example as the starting point.

# Local database: persistent SQLite file in the repo data directory.
DATABASE_URL="file:./data/app.db"

# Logging
LOG_LEVEL="info"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Auth.js secret
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional compatibility alias
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# Optional MCP integrations
TAVILY_API_KEY=""
FAL_API_KEY=""

# S3-compatible object storage
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="flashguides"

# SMTP (Mailhog in dev)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@flashguides.local"

# Optional test-only helpers
# PLAYWRIGHT_TEST="1"

# CI-only example
# FLY_API_TOKEN=""
