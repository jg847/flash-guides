# FlashGuides production environment for Vercel
# Set these values in Vercel Project Settings > Environment Variables.

# Remote SQLite-compatible database for production
DATABASE_URL="libsql://your-database.turso.io"
DATABASE_AUTH_TOKEN="replace-with-your-libsql-token"

# App URLs
NEXT_PUBLIC_APP_URL="https://your-domain.example.com"
AUTH_URL="https://your-domain.example.com"
NEXTAUTH_URL="https://your-domain.example.com"

# Auth.js secret
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional compatibility alias
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# Optional MCP integrations
TAVILY_API_KEY=""
FAL_API_KEY=""

# S3-compatible object storage
S3_ENDPOINT="https://<your-s3-endpoint>"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="flashguides"

# SMTP provider
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@your-domain.example.com"